rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper Functions
    function isSignedIn() { 
      return request.auth != null 
        && request.auth.token.email_verified == true; 
    }
    
    function isOwner(userId) { 
      return isSignedIn() && request.auth.uid == userId; 
    }
    
    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }
    
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // Validation Blueprints
    function isValidScore(data) {
      return data.keys().hasAll(['userId', 'displayName', 'score', 'level', 'timestamp'])
        && data.keys().size() == 5
        && data.userId == request.auth.uid
        && data.displayName is string && data.displayName.size() <= 64
        && data.score is number && data.score >= 0
        && data.level is number && data.level >= 1
        && data.timestamp == request.time;
    }

    function isValidUserProfile(data) {
      return data.keys().hasAll(['displayName'])
        && data.displayName is string && data.displayName.size() <= 64
        && (data.keys().size() == 1 || (data.keys().size() == 2 && (data.bestScore is number || data.streak is number)));
    }

    // Collections
    match /leaderboard/{scoreId} {
      allow list: if isSignedIn(); 
      allow get: if isSignedIn();
      
      allow create: if isSignedIn() 
        && isValidId(scoreId) 
        && isValidScore(incoming());
    }

    match /users/{userId} {
      allow get: if isSignedIn();
      allow create, update: if isOwner(userId) 
        && isValidId(userId)
        && isValidUserProfile(incoming());
    }
  }
}
